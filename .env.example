# Recommended: run purely from imported real data
DATA_PROVIDER=db
DATABASE_URL=sqlite:///data/cse_real.db
DB_CACHE_ENABLED=true
MODEL_DIR=models
ALLOW_PREDICTION_FALLBACK=false

# Optional admin protection
ADMIN_API_KEY=

# Optional live provider settings
CSE_API_BASE=https://www.cse.lk/api
CACHE_TTL_SECONDS=120
YF_EXCHANGE_SUFFIX=.CM
