DATA_PROVIDER=hybrid
DATABASE_URL=sqlite:///data/cse_real.db
DB_CACHE_ENABLED=true
MODEL_DIR=models
ALLOW_PREDICTION_FALLBACK=false
ADMIN_API_KEY=change-me
SESSION_COOKIE_NAME=cse_session
SESSION_TTL_DAYS=7
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeThisBeforeDeploy
CSE_API_BASE=https://www.cse.lk/api
CSE_TIMEOUT_SECONDS=8
CACHE_TTL_SECONDS=120
YF_EXCHANGE_SUFFIX=.CM

FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
FRONTEND_PUBLIC_URL=http://localhost:5173

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

FINBERT_ENABLED=true
FINBERT_MODEL=ProsusAI/finbert